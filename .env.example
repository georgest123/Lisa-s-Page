NEXT_PUBLIC_SUPABASE_URL=https://cfnkwzmdimkanhqlbpek.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public site URL (no trailing slash). Used for emails, Stripe success/cancel redirects, and calendar links.
# Set in Vercel Production to your real domain (e.g. https://lbeauclinique.com). If unset, the Stripe checkout API falls back to the request Host header — avoid relying on *.vercel.app when Deployment Protection is on.
NEXT_PUBLIC_SITE_URL=https://www.lbeauclinique.com

# Booking emails (server-only — add in Vercel / local .env)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
RESEND_API_KEY=re_your_resend_key
BOOKING_EMAIL_FROM=L Beaux Clinique <onboarding@resend.dev>
BOOKING_ADMIN_EMAIL=lbeauclinique@gmail.com
BOOKING_NOTIFY_WEBHOOK_SECRET=generate-a-long-random-string-for-supabase-webhook

# Google Calendar API — clinic calendar sync (server-only; optional)
# Requires SUPABASE_SERVICE_ROLE_KEY above so the server can read/write bookings during sync.
# Service account from GCP with Calendar API enabled; share your calendar with the SA email.
GOOGLE_CALENDAR_CLIENT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Usually your Google account email whose calendar is shared with the service account
GOOGLE_CALENDAR_CALENDAR_ID=lbeauclinique@gmail.com
# Optional: random secret for GET /api/health/google-calendar?secret=... (then remove from Vercel)
GOOGLE_CALENDAR_DIAGNOSTIC_SECRET=

# Stripe — booking deposits (server-only; optional)
# Create keys at https://dashboard.stripe.com/apikeys — use test keys while developing.
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret: Developers → Webhooks → endpoint → Signing secret (use Stripe CLI secret for local dev)
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: currency for Checkout (default gbp)
# STRIPE_CURRENCY=gbp
